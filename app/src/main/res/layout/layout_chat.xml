<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0F172A">

    <TextView
        android:id="@+id/btnBackFromChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="〈 返回"
        android:textColor="#B3FFFFFF"
        android:textSize="16sp"
        android:padding="20dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="語音助手服務中"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardRecord"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="40dp"
        app:cardBackgroundColor="#FF3B30"
        app:cardElevation="12dp"
        android:layout_centerInParent="true"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <Button
            android:id="@+id/btnSendChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:text="錄音"
            android:textSize="16sp"
            android:textColor="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layoutVisualizer"
        android:layout_width="220dp"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_below="@+id/cardRecord"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:visibility="invisible">

        <View android:id="@+id/vBar1" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar2" android:layout_width="10dp" android:layout_height="15dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar3" android:layout_width="10dp" android:layout_height="20dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar4" android:layout_width="10dp" android:layout_height="15dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar5" android:layout_width="12dp" android:layout_height="25dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" /> <View android:id="@+id/vBar6" android:layout_width="10dp" android:layout_height="15dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar7" android:layout_width="10dp" android:layout_height="20dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar8" android:layout_width="10dp" android:layout_height="15dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
        <View android:id="@+id/vBar9" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bar_technology_style" android:layout_margin="3dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="講完「小美」後稍微停頓\n等待提示音響起後再開始說出您的需求"
        android:textColor="#94A3B8"
        android:gravity="center"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="60dp" />

</RelativeLayout>