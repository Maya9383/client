<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f4f7f6"
    android:padding="20dp">

    <TextView
        android:id="@+id/btnBackFromControl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="〈 返回首頁"
        android:padding="10dp"
        android:textColor="#888888"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="15dp"
        android:text="30s 後自動返航"
        android:textColor="#FF7043"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_centerInParent="true"
        android:weightSum="2">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:padding="10dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="任務選擇" android:textSize="18sp" android:textStyle="bold" android:layout_gravity="center" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnCharge" android:layout_width="match_parent" android:layout_height="60dp" android:text="🔋 返回充電" android:backgroundTint="#2196F3"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:padding="10dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="前往地點" android:textSize="18sp" android:textStyle="bold" android:layout_gravity="center" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnDestLobby" android:layout_width="match_parent" android:layout_height="50dp" android:text="大廳" android:layout_marginBottom="10dp" android:backgroundTint="#FFFFFF" android:textColor="#333333"/>
        <Button android:id="@+id/btnDestWashroom" android:layout_width="match_parent" android:layout_height="50dp" android:text="洗手間" android:layout_marginBottom="10dp" android:backgroundTint="#FFFFFF" android:textColor="#333333"/>
        <Button android:id="@+id/btnDestStandby" android:layout_width="match_parent" android:layout_height="50dp" android:text="待機點" android:backgroundTint="#FFFFFF" android:textColor="#333333"/>
    </LinearLayout>
</LinearLayout>
</RelativeLayout>