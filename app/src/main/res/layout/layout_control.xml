<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F8FF"
    android:padding="20dp">

    <TextView
        android:id="@+id/btnBackFromControl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="〈 返回首頁"
        android:textColor="#005C8A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="30s 後自動返航"
        android:textColor="#FF3B30"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btnBackFromControl"
        app:layout_constraintBottom_toBottomOf="@id/btnBackFromControl"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="請選擇機器人任務與目的地"
        android:textColor="#333333"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBackFromControl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        android:weightSum="1"
        app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="20dp"
            android:layout_marginEnd="10dp"
            android:backgroundTint="#F4F7F6"
            android:elevation="4dp"
            android:background="@drawable/card_technology_style"> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="任務種類"
            android:textColor="#005C8A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="50dp"/>

            <Button
                android:id="@+id/btnCharge"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:text="⚡ 返回充電"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="20dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="#FFFFFF"
            android:elevation="4dp"
            android:background="@drawable/card_technology_style">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="前往目的地"
                android:textColor="#333333"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <Button
                android:id="@+id/btnDestLobby"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="大廳"
                android:textSize="24sp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#333333"
                android:elevation="2dp"/>

            <Button
                android:id="@+id/btnDestWashroom"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="洗手間"
                android:textSize="24sp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#333333"
                android:elevation="2dp"/>

            <Button
                android:id="@+id/btnDestStandby"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="待機點"
                android:backgroundTint="#FFFFFF"
                android:textColor="#333333"
                android:textSize="24sp"
                android:elevation="2dp"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>