<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:padding="24dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackFromControl"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_back_home"
        android:textColor="@color/md_theme_primary"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="@string/control_countdown"
        android:textColor="@color/md_theme_error"
        android:textSize="20sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btnBackFromControl"
        app:layout_constraintBottom_toBottomOf="@id/btnBackFromControl"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/control_title"
        android:textColor="@color/md_theme_onBackground"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBackFromControl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTaskType"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="@color/md_theme_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintHorizontal_weight="0.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardDestination"
        app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="top|center_horizontal"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/control_task_type"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="40dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCharge"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:text="@string/btn_charge"
                    android:textSize="28sp"
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    app:backgroundTint="@color/md_theme_primaryContainer"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:background="@color/theme_card_accent_blue" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDestination"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="12dp"
        app:cardBackgroundColor="@color/md_theme_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintHorizontal_weight="0.6"
        app:layout_constraintStart_toEndOf="@id/cardTaskType"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="top|center_horizontal"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/control_destination"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="40dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDestLobby"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:text="@string/btn_dest_lobby"
                        android:textSize="26sp"
                        android:layout_marginBottom="24dp"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        app:backgroundTint="@color/md_theme_surfaceVariant"
                        app:cornerRadius="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDestWashroom"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:text="@string/btn_dest_washroom"
                        android:textSize="26sp"
                        android:layout_marginBottom="24dp"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        app:backgroundTint="@color/md_theme_surfaceVariant"
                        app:cornerRadius="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDestStandby"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:text="@string/btn_dest_standby"
                        android:textSize="26sp"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        app:backgroundTint="@color/md_theme_surfaceVariant"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </ScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:background="@color/theme_card_accent_green" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>